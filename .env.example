# PostgreSQL settings
DB_HOST=db-postgres
DB_PORT=5432
DB_NAME=demo
DB_USER=demo
DB_PASSWORD=demo

# Domain and TLS settings (used by ingress and cert-manager)
# Replace with your actual domain and contact email
DOMAIN=example.com
EMAIL=admin@example.com

# ArgoCD Git repository configuration
GIT_REPO_URL=https://github.com/your-user/db-k8s-stack.git
# The branch ArgoCD should track
GIT_REPO_BRANCH=main
